# ============================================================================
# NoobBook Docker Environment Variables
# Copy to docker/.env and fill in your API keys before running docker/setup.sh
# ============================================================================

# --- Required API Keys ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
PINECONE_API_KEY=
PINECONE_INDEX_NAME=

# --- Optional API Keys ---
ELEVENLABS_API_KEY=
TAVILY_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Optional AI/Media Generation Keys ---
# These can also be added later via Settings → API Keys in the UI.
NANO_BANANA_API_KEY=
GEMINI_2_5_API_KEY=
VEO_API_KEY=

# --- Jira Integration (Optional) ---
# If configured, enables Jira tools in chat for querying projects and issues
# New format (recommended): Use JIRA_CLOUD_ID with Atlassian API gateway
# Get Cloud ID: curl -u 'email:token' https://api.atlassian.com/oauth/token/accessible-resources
JIRA_CLOUD_ID=
JIRA_EMAIL=
JIRA_API_KEY=
# Legacy format: Use JIRA_DOMAIN instead of JIRA_CLOUD_ID (still works)
# JIRA_DOMAIN=https://your-company.atlassian.net

# --- Notion Integration (Optional) ---
# If configured, enables Notion tools in chat for querying pages and databases
NOTION_API_KEY=

# --- Anthropic Tier (1-4, controls rate limits) ---
ANTHROPIC_TIER=1

# --- Auth / RBAC ---
# Set to true to require login for all API routes.
NOOBBOOK_AUTH_REQUIRED=true
# Comma-separated emails that should be promoted to admin on signup.
NOOBBOOK_ADMIN_EMAILS=
# Optional: create or reset an admin user on startup.
NOOBBOOK_BOOTSTRAP_ADMIN_EMAIL=
NOOBBOOK_BOOTSTRAP_ADMIN_PASSWORD=
# Set to true to reset password if the admin user already exists.
NOOBBOOK_BOOTSTRAP_ADMIN_FORCE_RESET=false

# --- Flask ---
SECRET_KEY=change-me-to-a-random-string

# --- CORS (set to your domain in production) ---
ALLOWED_ORIGINS=http://localhost

# --- Backend port (exposed on host, default 5001) ---
# All API traffic goes through nginx on port 80. Direct backend access is optional.
# BACKEND_PORT=5001

# --- Supabase (auto-generated by setup.sh — do not edit manually) ---
SUPABASE_URL=http://supabase-kong:8000
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# --- Postgres password (auto-generated by setup.sh) ---
POSTGRES_PASSWORD=
